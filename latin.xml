	<pronunciation nb="no silent letters in Latin; long vowels take about twice as long to say as short ones, cf: crotchets and quavers">
		<vowel>
			<a>between u in cup and a in cat; like first a in a-ha!</a>
			<ā>like a in father</ā>
			<e>like e in jet</e>
			<ē>like e in prey</ē>
			<i>like i in Itālia (not pit), or like y in yet when used as a consonant</i>
			<ī>like i in machine</ī>
			<o>like o in hot</o>
			<ō>like o in tone, although closer is French o in chose</ō>
			<u>like u in put, unless it follows q in which case its like w in qwick</u>
			<ū>like u food</ū>
			<y>like French u in tu</y>
		</vowel>
		<consonant>
			<b>as b in but</b>
			<c>as c in cut, not as in church, cider or loch</c>
			<d>as d in dog</d>
			<f>as f in fat</f>
			<g>as g in gut, not as in genius</g>
			<h>as h in hut</h>
			<k nb="only appears in kalendae;first day of the month">as k in kin</k>
			<l>as l in lit</l>
			<m>as m in mum</m>
			<n>as n in nut, but as ng before c, g and qu</n>
			<p>as p in pat</p>
			<q>as q in queen; is always followed by u</q>
			<r>always rolled like in Italian</r>
			<s>as s in sun, not as in was, treasure or sugar</s>
			<t>as t in top, not as in motion</t>
			<v>as w in win, although closer is the Hindi pronunciation of v</v>
			<x nb="is the double consonant ks">as x in axe, not as in exact</x>
			<z nb="only used in words of Greek origin">as z in zoo</z>
		</consonant>
		<diphthong>
			<ae eg="praeda:booty">like ai in aisle</ae>
			<au eg="aurum:gold">like ou in house</au>
			<oe eg="poena:penalty">like oi in boil</oe>
			<ei nb="rare as a diphthong; only found in the exclamations ei! eia! heia!;oh! aha! and Pompeii">like ei in reign</ei>
			<eu nb="rare as a diphthong" eg="seu:whether">like ew in pew</eu>
			<ui nb="rare as a diphthong" eg="huic:to this">like wea in weak</ui>
		</diphthong>
		<nondiphthong nb="usually, these are not diphthongs and are pronounced separately">
			<ei eg="mei:mine">mei=mayee</ei>
			<eu eg="deus:god">deus=dayoos</eu>
			<ui eg="tui:yours">tui=tooee</ui>
		</nondiphthong>
		<syllable>
			<syllabification1 eg="de-a;de-ae">separate two contiguous vowels or a vowel and diphthong</syllabification1>
			<syllabification2 eg="a-mī-cus">a single consonant between two vowels goes with the second vowel</syllabification2>
			<syllabification3 eg="mit-tō;ser-vā-re;cōn-sūmp-tus">when two or more consonants sit between vowels, generally only the second consonant goes with the following vowel</syllabification3>
			<syllabification4 eg="pa-trem;cas-tra">a stop (p|b|t|d|c|g) plus a liquid (l|r) generally count as a single consonant so go with the following vowel</syllabification4>
			<syllabification5 eg="ar-chi-tec-tus;lo-quā-cem">qu and the aspirates (ch|ph|th) count as single consonants which should never by separated in syllabification</syllabification5>
			<longshort>the difference is rather like that between a crotchet and a quaver</longshort>
			<long>long vowel|diphthong|ends in two consonants|ends in x|ends in single consonant and next word begins with a consonant</long>
			<longbynature eg="s1s2:lau-dō;s1:Rō-ma;s2:a-mī-cus">long vowel|diphthong</longbynature>
			<longbyposition eg="s1:ser-vat;s3:sa-pi-ēn-ti;s1:ax-is">short vowel followed by two or more consonants or by x (ks)</longbyposition>
		</syllable>
	</pronunciation>
	<mood>
		<finitemood nb="Finite moods are limited to a particular person">
			<indicativemood>generally for making statements and asking questions</indicativemood>
			<imperativemood>used for giving commands</imperativemood>
			<subjunctivemood>used mainly as a verb in subordinate clauses, often to express anticipated or conditional actions; less commonly, when it is a main verb, it usually expresses a wish and is often found in mottos</subjunctivemood>
		</finitemood>
